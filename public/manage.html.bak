<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>试卷管理 - 资料上传系统</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: linear-gradient(135deg, #0a0a1a 0%, #1a1a3a 100%); min-height: 100vh; }
    .glass-card { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
  </style>
</head>
<body class="text-white">
  <div class="container mx-auto px-4 py-8 max-w-7xl">
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-4">
        <a href="/up/login.html" class="text-gray-400 hover:text-white">← 返回</a>
        <h1 class="text-2xl font-bold"><span class="bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">📚 试卷管理</span></h1>
      </div>
      <div class="flex items-center gap-4">
        <a href="/up/changelog.html" class="text-gray-400 hover:text-white text-sm">📝 更新日志</a>
        <span class="text-gray-400 text-sm">共 <span id="totalCount">0</span> 份试卷</span>
      </div>
    </div>

    <!-- 搜索和操作区 -->
    <div class="glass-card rounded-xl p-4 mb-6">
      <div class="flex flex-wrap gap-4 items-center">
        <input type="text" id="searchInput" placeholder="搜索试卷名称..." class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 flex-1 min-w-[200px]">
        <select id="gradeFilter" class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700">
          <option value="">全部年级</option>
          <option value="7">初一</option>
          <option value="8">初二</option>
          <option value="9">初三</option>
        </select>
        <select id="subjectFilter" class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700">
          <option value="">全部科目</option>
          <option value="1">语文</option>
          <option value="2">数学</option>
          <option value="3">英语</option>
          <option value="4">物理</option>
          <option value="5">化学</option>
        </select>
        <select id="typeFilter" class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700">
          <option value="">全部类型</option>
          <option value="1">月考</option>
          <option value="2">期中</option>
          <option value="3">期末</option>
          <option value="4">一模</option>
          <option value="5">二模</option>
          <option value="6">开学考试</option>
        </select>
        <button onclick="searchPapers()" class="px-6 py-2 rounded-lg bg-cyan-600 hover:bg-cyan-500">🔍 搜索</button>
        <button onclick="batchDelete()" class="px-4 py-2 rounded-lg bg-red-600 hover:bg-red-500">🗑️ 批量删除</button>
      </div>
    </div>

    <!-- 试卷列表 -->
    <div class="glass-card rounded-xl overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-800/50">
          <tr class="text-gray-400">
            <th class="p-3 text-left w-10"><input type="checkbox" id="selectAll" onchange="toggleSelectAll()"></th>
            <th class="p-3 text-left">试卷名称</th>
            <th class="p-3 text-center w-16">年级</th>
            <th class="p-3 text-center w-16">科目</th>
            <th class="p-3 text-center w-20">类型</th>
            <th class="p-3 text-center w-20">大小</th>
            <th class="p-3 text-center w-24">下载</th>
            <th class="p-3 text-center w-28">上传时间</th>
            <th class="p-3 text-center w-24">操作</th>
          </tr>
        </thead>
        <tbody id="paperList"></tbody>
      </table>
    </div>

    <div id="pagination" class="flex justify-center gap-2 mt-6"></div>
  </div>

  <!-- 删除确认模态框 -->
  <div id="deleteModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="glass-card rounded-xl p-6 w-96">
      <h3 class="text-lg font-semibold mb-4">🔒 确认删除</h3>
      <p class="text-gray-400 mb-4">请输入管理员密码确认删除 <span id="deleteCount">0</span> 个试卷：</p>
      <input type="password" id="deletePassword" class="w-full px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 mb-4" placeholder="请输入密码" onkeypress="if(event.key==='Enter')confirmDelete()">
      <div class="flex gap-2 justify-end">
        <button onclick="closeDeleteModal()" class="px-4 py-2 rounded-lg bg-gray-600 hover:bg-gray-500">取消</button>
        <button onclick="confirmDelete()" class="px-4 py-2 rounded-lg bg-red-600 hover:bg-red-500">确认删除</button>
      </div>
    </div>
  </div>

  <script>
    let papers = [], selectedIds = [], deleteIds = [], currentPage = 1, totalCount = 0;
    const pageSize = 20;
    const subjectNames = { 1: '语文', 2: '数学', 3: '英语', 4: '物理', 5: '化学' };
    const gradeNames = { 7: '初一', 8: '初二', 9: '初三' };
    const typeNames = { 1: '月考', 2: '期中', 3: '期末', 4: '一模', 5: '二模', 6: '开学考试', 7: '单元测试' };

    document.addEventListener('DOMContentLoaded', loadPapers);
    document.getElementById('searchInput').addEventListener('keypress', e => { if(e.key==='Enter') searchPapers(); });

    async function loadPapers() {
      try {
        const res = await fetch('/sjxz/api/papers');
        const data = await res.json();
        totalCount = data.total || 0;
        papers = data.papers || [];
        document.getElementById('totalCount').textContent = totalCount;
        filterAndRender();
      } catch (e) {
        document.getElementById('paperList').innerHTML = '<tr><td colspan="9" class="p-4 text-center text-gray-500">加载失败: ' + e.message + '</td></tr>';
      }
    }

    function searchPapers() {
      currentPage = 1;
      filterAndRender();
    }

    function filterAndRender() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const grade = document.getElementById('gradeFilter').value;
      const subject = document.getElementById('subjectFilter').value;
      const type = document.getElementById('typeFilter').value;
      
      let filtered = papers.filter(p => {
        if (search && !p.title.toLowerCase().includes(search)) return false;
        if (grade && p.grade_id != grade) return false;
        if (subject && p.subject_id != subject) return false;
        if (type && p.type_id != type) return false;
        return true;
      });
      
      renderPapers(filtered);
    }

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1024 / 1024).toFixed(1) + ' MB';
    }

    function renderPapers(list) {
      const start = (currentPage - 1) * pageSize;
      const page = list.slice(start, start + pageSize);
      
      if (page.length === 0) {
        document.getElementById('paperList').innerHTML = '<tr><td colspan="9" class="p-8 text-center text-gray-500">暂无数据</td></tr>';
        document.getElementById('pagination').innerHTML = '';
        return;
      }
      
      document.getElementById('paperList').innerHTML = page.map(p => `
        <tr class="border-t border-gray-800 hover:bg-white/5">
          <td class="p-3"><input type="checkbox" class="paper-cb" value="${p.id}" onchange="updateSelection()"></td>
          <td class="p-3 truncate max-w-md" title="${p.title}">${p.title}</td>
          <td class="p-3 text-center">${gradeNames[p.grade_id] || '-'}</td>
          <td class="p-3 text-center">${subjectNames[p.subject_id] || '-'}</td>
          <td class="p-3 text-center">${typeNames[p.type_id] || '-'}</td>
          <td class="p-3 text-center text-gray-400">${formatSize(p.file_size)}</td>
          <td class="p-3 text-center text-gray-400">${p.download_count || 0}</td>
          <td class="p-3 text-center text-gray-400">${p.created_at?.substring(0, 10) || '-'}</td>
          <td class="p-3 text-center">
            <button onclick="downloadPaper(${p.id})" class="text-cyan-400 hover:text-cyan-300 mr-2">下载</button>
            <button onclick="deletePaper(${p.id})" class="text-red-400 hover:text-red-300">删除</button>
          </td>
        </tr>
      `).join('');
      
      renderPagination(list.length);
    }

    function renderPagination(total) {
      const pages = Math.ceil(total / pageSize);
      if (pages <= 1) { document.getElementById('pagination').innerHTML = ''; return; }
      
      let html = `<button onclick="goPage(${currentPage-1})" class="px-3 py-1 rounded ${currentPage===1?'bg-gray-700 opacity-50':'bg-gray-700 hover:bg-gray-600'}" ${currentPage===1?'disabled':''}>上一页</button>`;
      for (let i = 1; i <= Math.min(pages, 5); i++) {
        html += `<button onclick="goPage(${i})" class="px-3 py-1 rounded ${i === currentPage ? 'bg-cyan-600' : 'bg-gray-700 hover:bg-gray-600'}">${i}</button>`;
      }
      if (pages > 5) html += `<span class="px-2">...</span><button onclick="goPage(${pages})" class="px-3 py-1 rounded bg-gray-700 hover:bg-gray-600">${pages}</button>`;
      html += `<button onclick="goPage(${currentPage+1})" class="px-3 py-1 rounded ${currentPage===pages?'bg-gray-700 opacity-50':'bg-gray-700 hover:bg-gray-600'}" ${currentPage===pages?'disabled':''}>下一页</button>`;
      document.getElementById('pagination').innerHTML = html;
    }

    function goPage(p) { currentPage = Math.max(1, p); filterAndRender(); }

    function toggleSelectAll() {
      const checked = document.getElementById('selectAll').checked;
      document.querySelectorAll('.paper-cb').forEach(cb => cb.checked = checked);
      updateSelection();
    }

    function updateSelection() {
      selectedIds = Array.from(document.querySelectorAll('.paper-cb:checked')).map(cb => parseInt(cb.value));
    }

    function batchDelete() {
      if (selectedIds.length === 0) { alert('请先选择要删除的试卷'); return; }
      deleteIds = selectedIds;
      document.getElementById('deleteCount').textContent = deleteIds.length;
      document.getElementById('deleteModal').classList.remove('hidden');
      document.getElementById('deletePassword').focus();
    }

    function deletePaper(id) {
      deleteIds = [id];
      document.getElementById('deleteCount').textContent = 1;
      document.getElementById('deleteModal').classList.remove('hidden');
      document.getElementById('deletePassword').focus();
    }

    function closeDeleteModal() {
      document.getElementById('deleteModal').classList.add('hidden');
      document.getElementById('deletePassword').value = '';
    }

    async function confirmDelete() {
      const password = document.getElementById('deletePassword').value;
      if (!password) { alert('请输入密码'); return; }
      
      try {
        const res = await fetch('/sjxz/api/admin/papers/batch/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids: deleteIds, password })
        });
        const data = await res.json();
        if (data.success) {
          alert(`成功删除 ${data.count} 个试卷`);
          closeDeleteModal();
          loadPapers();
        } else {
          alert('删除失败: ' + (data.error || '未知错误'));
        }
      } catch (e) {
        alert('删除失败: ' + e.message);
      }
    }

    function downloadPaper(id) {
      window.open('/sjxz/api/papers/' + id + '/download', '_blank');
    }
  </script>
    <script>
      // 登录检查
      const token = localStorage.getItem("up_token");
      if (!token) { window.location.href = "/up/login.html"; }
      fetch("/up/api/check-auth", { headers: { "Authorization":  } }).then(r => r.json()).then(d => {
        if (!d.success) { localStorage.removeItem("up_token"); window.location.href = "/up/login.html"; }
      });
    </script>
</body>
</html>
